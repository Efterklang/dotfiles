{
	"front matter": {
		"prefix": "front matter",
		"body": ["---", "cover:", "tags:", "---"],
		"description": "Create front matter block"
	},
	"Markdown Callout": {
		"prefix": "callout",
		"body": [
			"> [!${1|info,todo,success,check,done,warning,caution,attention,question,help,faq,danger,error,bug,failure,fail,missing,tips,hint,important,example,abstract,summary,tldr,quote,cite|}] ${2:message}"
		],
		"description": "Create a callout block with different types: NOTE, TIP etc."
	},
	"anchor": {
		"prefix": "anchor",
		"body": ["<a href=\"#$1\">$2</a>"]
	},
	"animated_image": {
		"prefix": "video",
		"body": [
			"<video autoplay loop muted playsinline>",
			"  <source src=\"$1\" type=\"video/webm\">",
			"</video>"
		]
	},
	"raw": {
		"prefix": "raw",
		"body": ["{% raw %}", "", "$1", "", "{% endraw %}"]
	},
	"style": {
		"prefix": "style",
		"body": ["<style>", "", "</style>"]
	},
	"div tag": {
		"prefix": "div",
		"body": ["<div>", "", "</div>"]
	},
	"tabs": {
		"prefix": "tab",
		"body": ["::: tabs", "@tab:active $1", "@tab $2", ":::"]
	},
	"math": {
		"prefix": "math",
		"body": ["$$", "\\begin{align*}", "& $1", "\\end{align*}", "$$"]
	},
	"heimu": {
		"prefix": "heimu",
		"body": "<span class=\"heimu\">$1</span>"
	},
	"columns": {
		"prefix": "twoColumnFlex",
		"body": [
			"<div style=\"display: flex; justify-content: space-between; align-items: flex-start; gap: 2rem;\">",
			"  <!-- Column 1-->",
			"  <div style=\"flex: 1;\">",
			"    ",
			"  </div>",
			"  <!-- Column 2-->",
			"  <div style=\"flex: 1;\">",
			"    ",
			"  </div>",
			"</div>"
		],
		"description": "A two-column flex layout with space between and flex-start alignment."
	},
	"cat-line": {
		"prefix": "cat-line",
		"body": [
			"<p align=\"center\">",
			" <img src=\"/img/misc/cat-line.svg?sanitize=true\" alt=\"cat-line\"/>",
			"</p>"
		],
		"description": "A centered cat line image."
	},
	"Accordion": {
		"prefix": ["x-accordion", "accordion"],
		"body": [
			"<script data-swup-reload-script type=\"module\" src=\"/js/components/accordion.js\"></script>",
			"<x-accordion>",
			"  <accordion-item title=\"$1\">",
			"    $2",
			"  </accordion-item>",
			"</x-accordion>"
		],
		"description": "Accordion custom element with expandable items"
	},
	"AccordionItem": {
		"prefix": ["x-accordion_item", "accordion_item"],
		"body": [
			"  <accordion-item title=\"$1\">",
			"    $2",
			"  </accordion-item>"
		],
		"description": "Accordion custom element with expandable items"
	},
	"TextImageSection": {
		"prefix": ["text-image", "ti-section"],
		"body": [
			"<script data-swup-reload-script type=\"module\" src=\"/js/components/text-image-section.js\"></script>",
			"<text-image-section image=\"$1\" alt=\"$2\" width=\"$3\">",
			"  $0",
			"</text-image-section>"
		],
		"description": "Text-image section with optional caption (alt) and width"
	},
	"ImageCarousel": {
		"prefix": ["image-carousel", "carousel"],
		"body": [
			"<script data-swup-reload-script type=\"module\" src=\"/js/components/image-carousel.js\"></script>",
			"<image-carousel${1/(autoplay)/(?: autoplay)/} interval=\"$2\" ratio=\"$3\">",
			"  ![]($4)",
			"  ![]($5)",
			"  ![]($6)",
			"</image-carousel>$0"
		],
		"description": "Image carousel with autoplay, interval and ratio support"
	}
}
