[http]
	postBuffer = 524288000
	lowSpeedLimit = 0
	lowSpeedTime = 999999
	version = HTTP/1.1
[credential]
	helper = store
[safe]
	directory = *
; [alias]
; 	dif = difftool
; 	merg = mergetool
[gui]
	recentrepo = E:/UESTC/Markdown
[core]
	editor = nvim
[sendpack]
	sideband = false
[init]
	defaultBranch = main
[http "https://github.com"]
	proxy = http://127.0.0.1:7890
