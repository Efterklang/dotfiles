[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[user]
	name = Efterklang
	email = gaojiaxing2004@qq.com
; [core]
	; editor = 'D:/Application/Microsoft VS Code Insiders/Code - Insiders.exe' -multiInst -notabbar -nosession -noPlugin
	; autocrlf = false
	; pager = code-insiders --wait -
; [diff]
; 	tool = vscode
; [difftool "vscode"]
; 	cmd = code-insiders --wait --diff $LOCAL $REMOTE
; [merge]
